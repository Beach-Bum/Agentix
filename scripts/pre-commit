#!/usr/bin/env bash
# Pre-commit checks: markdown, python syntax, unclosed code blocks
set -euo pipefail

ERRORS=0

# 1. Check markdown files for broken formatting
MD_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep '\.md$' || true)
if [ -n "$MD_FILES" ]; then
    # Check for unclosed code blocks (the exact bug we shipped)
    for f in $MD_FILES; do
        FENCES=$(grep -c '^```' "$f" || true)
        if (( FENCES % 2 != 0 )); then
            echo "ERROR: $f has an unclosed code block ($FENCES fence lines)"
            ERRORS=1
        fi
    done

    # Run markdownlint if available
    if command -v markdownlint &>/dev/null; then
        echo "$MD_FILES" | xargs markdownlint --disable MD013 MD033 MD041 || ERRORS=1
    fi
fi

# 2. Check python syntax
PY_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep '\.py$' || true)
if [ -n "$PY_FILES" ]; then
    for f in $PY_FILES; do
        python3 -c "import ast; ast.parse(open('$f').read())" 2>&1 || {
            echo "ERROR: $f has a syntax error"
            ERRORS=1
        }
    done

    # Run ruff if available
    if command -v ruff &>/dev/null; then
        echo "$PY_FILES" | xargs ruff check --select E,F || ERRORS=1
    fi
fi

# 3. Check nix syntax
NIX_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep '\.nix$' || true)
if [ -n "$NIX_FILES" ]; then
    if command -v nix &>/dev/null; then
        for f in $NIX_FILES; do
            nix-instantiate --parse "$f" >/dev/null 2>&1 || {
                echo "ERROR: $f has a nix syntax error"
                ERRORS=1
            }
        done
    fi
fi

if [ "$ERRORS" -ne 0 ]; then
    echo ""
    echo "Pre-commit checks failed. Fix the errors above before committing."
    exit 1
fi
